{
  "description": "Core plugin hooks - context loading and command validation",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/load_context_map.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
